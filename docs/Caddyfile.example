# Cofemine Panel — пример секции для Caddy
#
# Предпосылки:
#  1) На хосте один раз создан shared network:
#        docker network create caddy_net
#  2) Ваш Caddy-контейнер подключён к этой сети (см. ниже).
#  3) docker-compose.prod.yml панели уже подключает `web` к той же сети.
#
# Caddy тогда резолвит `web` по Docker DNS и ходит напрямую — никаких
# публичных портов у web нет, `host.docker.internal` не нужен.
#
# TLS и WebSocket-апгрейды Caddy тянет сам, без дополнительных директив.

panel.cofemine.ru {
	reverse_proxy web:3000
	tls cofedish@gmail.com
}

# ----------------------------------------------------------------------
# Минимальный docker-compose для самого Caddy (если нужно с нуля):
#
# services:
#   caddy:
#     image: caddy:2
#     restart: always
#     ports:
#       - "80:80"
#       - "443:443"
#       - "443:443/udp"     # HTTP/3
#     volumes:
#       - ./Caddyfile:/etc/caddy/Caddyfile:ro
#       - caddy_data:/data
#       - caddy_config:/config
#     networks: [caddy_net]
#
# volumes:
#   caddy_data:
#   caddy_config:
#
# networks:
#   caddy_net:
#     external: true

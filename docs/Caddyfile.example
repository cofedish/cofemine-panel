# Cofemine Panel — пример секции для Caddy
#
# Предпосылки:
#  1) У вас уже есть shared network, на которую навешан Caddy (например
#     `caddy`). docker-compose.prod.yml панели по умолчанию подключает
#     `web` к сети с именем `caddy` — переопределяется через
#     переменную CADDY_NETWORK в .env.
#  2) Caddy и web видят друг друга по Docker DNS, так что
#     `reverse_proxy web:3000` работает напрямую.
#
# Caddy тогда резолвит `web` по Docker DNS и ходит напрямую — никаких
# публичных портов у web нет, `host.docker.internal` не нужен.
#
# TLS и WebSocket-апгрейды Caddy тянет сам, без дополнительных директив.

panel.cofemine.ru {
	reverse_proxy web:3000
	tls cofedish@gmail.com
}

# ----------------------------------------------------------------------
# Минимальный docker-compose для самого Caddy (если нужно с нуля):
#
# services:
#   caddy:
#     image: caddy:2
#     restart: always
#     ports:
#       - "80:80"
#       - "443:443"
#       - "443:443/udp"     # HTTP/3
#     volumes:
#       - ./Caddyfile:/etc/caddy/Caddyfile:ro
#       - caddy_data:/data
#       - caddy_config:/config
#     networks: [caddy_net]
#
# volumes:
#   caddy_data:
#   caddy_config:
#
# networks:
#   caddy_net:
#     external: true

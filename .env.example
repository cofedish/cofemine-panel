# ===== Panel API =====
API_PORT=4000
API_HOST=0.0.0.0
# Public base URL of the API (used by the web app). When running compose, panel-web talks to panel-api via service DNS.
API_PUBLIC_URL=http://localhost:4000

# Postgres
POSTGRES_USER=cofemine
POSTGRES_PASSWORD=cofemine
POSTGRES_DB=cofemine
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cofemine:cofemine@db:5432/cofemine?schema=public

# Auth
JWT_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=168

# Encryption key for secrets stored in DB (base64 32 bytes). Generate: openssl rand -base64 32
SECRETS_KEY=REPLACE_WITH_BASE64_32B

# Bootstrap: if set, first-run setup will auto-create this owner on startup (optional)
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_USERNAME=
BOOTSTRAP_OWNER_PASSWORD=

# ===== Node Agent (default "local" node) =====
AGENT_PORT=4100
AGENT_HOST=0.0.0.0
# Shared secret the API uses to authenticate against this agent
AGENT_TOKEN=change-me-agent-token
# Host path where the agent stores server data (mounted into MC containers as /data)
AGENT_DATA_ROOT=/var/lib/cofemine/servers
AGENT_BACKUP_ROOT=/var/lib/cofemine/backups
# Docker network that MC containers should join (optional)
AGENT_DOCKER_NETWORK=cofemine_mcnet
# Label prefix for managed containers
AGENT_LABEL_PREFIX=cofemine

# ===== Web =====
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ===== Integrations =====
MODRINTH_USER_AGENT=cofemine-panel/0.1 (https://github.com/cofemine/panel)
# CurseForge API key is stored via the Integrations UI (optional at start)
